# Server mode: debug or release
GIN_MODE=debug

# Application display name
APP_NAME=TwitchAIBot

# HTTP server port
SERVER_PORT=8080

# Trusted proxy addresses (CIDR format, comma separated)
SERVER_TRUSTED_PROXIES=localhost

# Twitch OAuth Client ID from dev.twitch.tv
TWITCH_CLIENT_ID=your_client_id

# Twitch OAuth Client Secret from dev.twitch.tv
TWITCH_CLIENT_SECRET=your_client_secret

# OAuth redirect URL (must match Twitch app settings)
TWITCH_CLIENT_REDIRECT_URI=http://localhost:8080/api/auth/callback/twitch

# Twitch broadcaster channel ID to monitor
TWITCH_BROADCASTER_ID=your_id

# Twitch bot account ID
TWITCH_BOT_USER_ID=your_id

# Twitch bot username
TWITCH_BOT_USER_NAME=your_name

# Keyword to trigger the bot in chat
TWITCH_KEY_WORD_TO_CALL_BOT=jesus

# Max message length in Twitch chat
TWITCH_CHAT_MESSAGE_MAX_LENGTH=500

# Time interval for the bot to tell jokes
TWITCH_TIME_FOR_THE_BOT_TO_TELLA_JOKE=5m

# Groq API key from console.groq.com
GROQ_API_KEY=your_key

# Groq models (comma separated, first available is used)
GROQ_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-120b

# Max messages kept in conversation context
GROQ_MAX_CONTEXT_INPUT=6

# Max request timeout for AI responses
CONTEXT_REQUEST_DURATION=10s
